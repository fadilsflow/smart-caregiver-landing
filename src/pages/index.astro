---
import LandingHero from "../components/LandingHero.astro";
import LandingSections from "../components/LandingSections.astro";
import generatedDashboard from "../data/generated-dashboard";
import type { DashboardSummary } from "../lib/types";
import "../styles/global.css";

const dashboard = generatedDashboard as unknown as DashboardSummary;
---

<html lang="id">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta
            name="description"
            content="Smart Caregiver — Dashboard data kesehatan lansia Indonesia dari WHO, Google Trends, dan YouTube dengan visualisasi indikator kesehatan dan analisis sentimen."
        />
        <title>Smart Caregiver — Dashboard Kesehatan Lansia Indonesia</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <main>
            <LandingHero />
            <LandingSections keyMetrics={dashboard.keyMetrics} />
        </main>
    </body>
</html>
