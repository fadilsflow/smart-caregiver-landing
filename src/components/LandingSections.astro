---
// Landing sections — Smart Caregiver app promotion
import type { KeyMetrics } from '../lib/types';

export interface Props {
    keyMetrics: KeyMetrics;
}

const { keyMetrics } = Astro.props;
const rangeYears = keyMetrics.timerange.match(/\d{4}/g);
const displayRange = rangeYears?.length ? `${rangeYears[0]}–${rangeYears.at(-1)}` : keyMetrics.timerange;
---

<section class="promo-flow" aria-label="Smart Caregiver landing sections">
    <div class="promo-inner">

        <!-- Cara Kerja -->
        <section id="cara-kerja" class="section-pad">
            <div class="section-heading">
                <span class="eyebrow">Cara kerja</span>
                <h2>Satu aplikasi untuk merawat dengan lebih percaya diri.</h2>
                <p>
                    Smart Caregiver membantu keluarga mencatat kesehatan, mengatur
                    jadwal, dan mendapatkan rekomendasi aktivitas — tanpa harus
                    membuka banyak catatan terpisah.
                </p>
            </div>

            <div class="feature-grid">
                <article class="feature-card featured">
                    <span class="card-icon" aria-hidden="true">01</span>
                    <h3>Catat kesehatan harian</h3>
                    <p>
                        Tekanan darah, gula darah, detak jantung, suhu tubuh, dan
                        berat badan — semua bisa dicatat per lansia. Sistem otomatis
                        menandai <strong>Normal</strong> atau
                        <strong>Perlu Perhatian</strong>.
                    </p>
                </article>
                <article class="feature-card">
                    <span class="card-icon" aria-hidden="true">02</span>
                    <h3>Atur jadwal & alarm</h3>
                    <p>
                        Jadwalkan minum obat, pemeriksaan rutin, dan aktivitas harian.
                        Dilengkapi alarm pengingat dan notifikasi otomatis jika
                        parameter kesehatan melampaui ambang batas.
                    </p>
                </article>
                <article class="feature-card">
                    <span class="card-icon" aria-hidden="true">03</span>
                    <h3>Rekomendasi AI</h3>
                    <p>
                        Dapatkan saran aktivitas yang dipersonalisasi — senam kursi,
                        terapi musik, berkebun — berdasarkan usia, kondisi fisik,
                        dan minat lansia.
                    </p>
                </article>
            </div>
        </section>

        <!-- Fitur Detail -->
        <section class="insight-band section-pad">
            <div class="section-heading">
                <span class="eyebrow">Fitur unggulan</span>
                <h2>Dirancang untuk kebutuhan caregiver.</h2>
            </div>

            <div class="insight-grid">
                <article class="insight-card">
                    <span class="insight-number">Keamanan</span>
                    <h3>Verifikasi wajah</h3>
                    <p>
                        Registrasi dan login dengan face recognition — data kesehatan
                        lansia tetap aman karena hanya caregiver terverifikasi yang
                        bisa mengakses.
                    </p>
                </article>
                <article class="insight-card">
                    <span class="insight-number">Pantauan</span>
                    <h3>Dashboard & grafik tren</h3>
                    <p>
                        Lihat ringkasan semua lansia dalam satu tampilan. Grafik tren
                        per parameter kesehatan — 7 atau 30 hari — bantu deteksi
                        perubahan sejak dini.
                    </p>
                </article>
                <article class="insight-card">
                    <span class="insight-number">Notifikasi</span>
                    <h3>Peringatan cerdas</h3>
                    <p>
                        Alarm jadwal obat, notifikasi kondisi kritis, dan ringkasan
                        mingguan — caregiver selalu mendapat informasi tepat waktu.
                    </p>
                </article>
                <article class="insight-card">
                    <span class="insight-number">Teknologi</span>
                    <h3>Flutter + FastAPI + AI</h3>
                    <p>
                        Dibangun dengan Flutter untuk antarmuka yang responsif,
                        FastAPI di backend, dan AI untuk rekomendasi aktivitas yang
                        adaptif terhadap profil lansia.
                    </p>
                </article>
            </div>
        </section>

        <!-- Dashboard CTA -->
        <section class="dashboard-cta section-pad" aria-labelledby="cta-title">
            <div class="cta-content">
                <span class="eyebrow">Eksplorasi data</span>
                <h2 id="cta-title">Lihat data kesehatan lansia Indonesia.</h2>
                <p>
                    Dashboard publik kami merangkum indikator WHO, minat pencarian
                    Google Trends, dan percakapan YouTube — sebagai pelengkap
                    insight untuk pengguna aplikasi.
                </p>
                <a class="pill-btn primary" href="/public-dashboard">
                    Buka Dashboard Publik
                    <span class="arrow" aria-hidden="true">→</span>
                </a>
            </div>
            <div class="cta-visual" aria-hidden="true">
                <div class="cta-metric">
                    <strong>{keyMetrics.totalSources}</strong>
                    <span>Sumber data</span>
                </div>
                <div class="cta-metric">
                    <strong>{keyMetrics.totalRecords.toLocaleString('id-ID')}</strong>
                    <span>Record</span>
                </div>
                <div class="cta-metric">
                    <strong>{displayRange}</strong>
                    <span>Rentang waktu</span>
                </div>
            </div>
        </section>

        <!-- Download -->
        <section id="unduh" class="download-band section-pad" aria-labelledby="download-title">
            <div>
                <span class="eyebrow light">Unduh aplikasi</span>
                <h2 id="download-title">Mulai dampingi orang tersayang dengan lebih tenang.</h2>
                <p>
                    Catat kesehatan, atur jadwal, dapatkan rekomendasi AI — semua
                    dalam satu aplikasi. Tersedia di Android dan iOS.
                </p>
            </div>
            <div class="download-actions">
                <a class="store-button" href="#" aria-label="Unduh Smart Caregiver di Google Play">
                    <small>Segera hadir di</small>
                    <strong>Google Play</strong>
                </a>
                <a class="store-button secondary" href="#" aria-label="Unduh Smart Caregiver di App Store">
                    <small>Segera hadir di</small>
                    <strong>App Store</strong>
                </a>
            </div>
        </section>

    </div>
</section>

<style>
    .promo-flow {
        width: 100vw;
        margin: 0 calc(50% - 50vw);
    }

    .promo-inner {
        width: min(100% - 64px, 1280px);
        margin: 0 auto;
    }

    .section-pad {
        padding: clamp(56px, 7vw, 96px) 0;
    }

    .section-heading {
        max-width: 760px;
        margin-bottom: 40px;
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        margin-bottom: 16px;
        padding: 6px 14px;
        border-radius: var(--radius-pill);
        background: var(--surface);
        color: var(--charcoal);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .eyebrow.light {
        background: rgba(255, 255, 255, 0.1);
        color: var(--on-dark-soft);
    }

    .section-heading h2,
    .insight-band h2,
    .download-band h2 {
        font-size: clamp(1.75rem, 3.5vw, 3rem);
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.2;
    }

    .section-heading p,
    .cta-content p,
    .download-band p {
        max-width: 680px;
        margin-top: 16px;
        color: var(--charcoal);
        font-size: clamp(1rem, 1.2vw, 1.15rem);
        line-height: 1.65;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: 18px;
    }

    .feature-card {
        min-height: 280px;
        padding: var(--space-xl);
        border: 1px solid var(--hairline);
        border-radius: var(--radius-xxl);
        background: var(--canvas);
    }

    .feature-card.featured {
        background: var(--ink);
        color: var(--on-dark);
    }

    .feature-card.featured h3,
    .feature-card.featured p {
        color: var(--on-dark);
    }

    .feature-card.featured p strong {
        color: var(--on-dark);
    }

    .card-icon {
        display: inline-grid;
        place-items: center;
        width: 44px;
        height: 44px;
        margin-bottom: 48px;
        border-radius: var(--radius-full);
        background: var(--surface);
        color: var(--charcoal);
        font-size: 0.85rem;
        font-weight: 700;
    }

    .featured .card-icon {
        background: rgba(255, 255, 255, 0.12);
        color: var(--on-dark);
    }

    .feature-card h3 {
        margin-bottom: 10px;
        font-size: 1.2rem;
        font-weight: 600;
    }

    .feature-card p {
        color: var(--charcoal);
        font-size: 0.92rem;
        line-height: 1.6;
    }

    .featured .feature-card p {
        color: var(--on-dark-soft);
    }

    .insight-band {
        border-top: 1px solid var(--hairline-soft);
    }

    .insight-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .insight-card {
        padding: var(--space-xl);
        border: 1px solid var(--hairline);
        border-radius: var(--radius-xxl);
        background: var(--canvas);
    }

    .insight-number {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--steel);
        margin-bottom: 12px;
    }

    .insight-card h3 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .insight-card p {
        font-size: 0.92rem;
        color: var(--charcoal);
        line-height: 1.6;
    }

    .dashboard-cta {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 40px;
        align-items: center;
        margin-bottom: 48px;
        padding: clamp(32px, 5vw, 56px) clamp(32px, 5vw, 64px);
        border-radius: var(--radius-hero);
        background: var(--surface);
        border: 1px solid var(--hairline);
        overflow: hidden;
    }

    .cta-content .pill-btn {
        margin-top: 24px;
        min-width: 200px;
        padding: 14px 28px;
        font-size: 15px;
    }

    .cta-visual {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .cta-metric {
        display: grid;
        gap: 4px;
        padding: 20px 16px;
        border-radius: var(--radius-xl);
        background: var(--canvas);
        border: 1px solid var(--hairline);
        text-align: center;
    }

    .cta-metric strong {
        font-family: var(--font-heading);
        font-size: clamp(1.4rem, 2vw, 2rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--ink);
    }

    .cta-metric span {
        font-size: 0.82rem;
        color: var(--slate);
        font-weight: 500;
    }

    .download-band {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 36px;
        align-items: center;
        padding-inline: clamp(28px, 5vw, 56px);
        border-radius: var(--radius-hero);
        background: var(--ink);
        color: var(--on-dark);
        overflow: hidden;
    }

    .download-band h2,
    .download-band p {
        color: var(--on-dark);
    }

    .download-band p {
        color: var(--on-dark-soft);
    }

    .download-actions {
        display: grid;
        gap: 12px;
        min-width: 220px;
    }

    .store-button {
        display: grid;
        gap: 2px;
        padding: 14px 20px;
        border-radius: var(--radius-pill);
        background: var(--on-dark);
        color: var(--ink);
        text-align: center;
        transition: opacity 0.15s ease;
    }

    .store-button.secondary {
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: transparent;
        color: var(--on-dark);
    }

    .store-button small {
        color: inherit;
        opacity: 0.6;
        font-size: 0.78rem;
    }

    .store-button strong {
        font-family: var(--font-sans);
        font-size: 1.1rem;
        font-weight: 700;
    }

    @media (max-width: 900px) {
        .feature-grid {
            grid-template-columns: 1fr;
        }

        .feature-card {
            min-height: 0;
        }

        .card-icon {
            margin-bottom: 28px;
        }

        .dashboard-cta {
            grid-template-columns: 1fr;
            gap: 28px;
            margin-bottom: 32px;
        }
    }

    @media (max-width: 768px) {
        .insight-grid {
            grid-template-columns: 1fr;
        }

        .download-band {
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .download-actions {
            min-width: 0;
        }
    }

    @media (max-width: 640px) {
        .promo-inner {
            width: min(100% - 24px, 520px);
        }

        .dashboard-cta {
            border-radius: var(--radius-xxxl);
            padding: 24px 20px;
        }

        .cta-visual {
            gap: 8px;
        }

        .cta-metric {
            padding: 14px 8px;
            border-radius: var(--radius-lg);
        }

        .download-band {
            border-radius: var(--radius-xxxl);
            padding: 28px 20px;
        }

        .feature-card {
            padding: var(--space-lg);
        }
    }
</style>
