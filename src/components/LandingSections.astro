---
// Landing sections — custom Astro components with Starwind-inspired card, pill, and CTA patterns.
---

<section class="promo-flow" aria-label="Smart Caregiver landing sections">
    <div class="promo-inner">
        <section id="cara-kerja" class="feature-band section-pad">
            <div class="section-heading">
                <span class="eyebrow">Cara kerja</span>
                <h2>Satu tempat untuk membuat rutinitas merawat terasa lebih ringan.</h2>
                <p>
                    Smart Caregiver membantu keluarga menyusun jadwal, memahami
                    kebutuhan lansia, dan melihat prioritas perawatan tanpa harus
                    membuka banyak catatan terpisah.
                </p>
            </div>

            <div class="feature-grid">
                <article class="feature-card featured">
                    <span class="card-icon" aria-hidden="true">✓</span>
                    <h3>Atur agenda rawat</h3>
                    <p>
                        Jadwalkan obat, aktivitas, kontrol, hidrasi, dan catatan
                        penting agar pendamping tidak melewatkan hal kecil.
                    </p>
                </article>
                <article class="feature-card">
                    <span class="card-icon" aria-hidden="true">♡</span>
                    <h3>Pahami kondisi harian</h3>
                    <p>
                        Simpan catatan sederhana tentang mood, keluhan, dan
                        aktivitas agar keluarga punya konteks yang sama.
                    </p>
                </article>
                <article class="feature-card">
                    <span class="card-icon" aria-hidden="true">↗</span>
                    <h3>Lihat insight publik</h3>
                    <p>
                        Dashboard data memberi gambaran tren kesehatan lansia,
                        percakapan digital, dan topik yang sering dicari.
                    </p>
                </article>
            </div>
        </section>

        <section class="dashboard-cta section-pad" aria-labelledby="cta-title">
            <div class="cta-content">
                <span class="eyebrow">Dashboard publik</span>
                <h2 id="cta-title">Lihat data kesehatan lansia dari tiga sumber.</h2>
                <p>
                    Jelajahi dashboard interaktif yang merangkum indikator WHO, minat
                    pencarian Google Trends, dan percakapan YouTube — semua disajikan
                    dalam satu tampilan.
                </p>
                <a class="cta-action" href="/public-dashboard">
                    <span aria-hidden="true">▸</span>
                    Buka Dashboard
                </a>
            </div>
            <div class="cta-visual" aria-hidden="true">
                <div class="cta-metric">
                    <strong>143+</strong>
                    <span>Indikator WHO</span>
                </div>
                <div class="cta-metric">
                    <strong>5 Thn</strong>
                    <span>Rentang Waktu</span>
                </div>
                <div class="cta-metric">
                    <strong>4K</strong>
                    <span>Video YouTube</span>
                </div>
            </div>
        </section>

        <section id="unduh" class="download-band section-pad" aria-labelledby="download-title">
            <div>
                <span class="eyebrow light">Unduh aplikasi</span>
                <h2 id="download-title">Mulai dampingi orang tersayang dengan lebih tenang.</h2>
                <p>
                    Siapkan rutinitas rawat, bagikan catatan ke keluarga, dan gunakan
                    insight kesehatan lansia sebagai bahan memahami kebutuhan harian.
                </p>
            </div>
            <div class="download-actions">
                <a class="store-button" href="#" aria-label="Unduh Smart Caregiver di Google Play">
                    <small>Segera hadir di</small>
                    <strong>Google Play</strong>
                </a>
                <a class="store-button secondary" href="#" aria-label="Unduh Smart Caregiver di App Store">
                    <small>Segera hadir di</small>
                    <strong>App Store</strong>
                </a>
            </div>
        </section>
    </div>
</section>

<style>
    .promo-flow {
        width: 100vw;
        margin: 0 calc(50% - 50vw);
        background:
            linear-gradient(180deg, var(--canvas) 0%, var(--blue-soft) 44%, var(--canvas) 100%);
    }

    .promo-inner {
        width: min(100% - 48px, 1180px);
        margin: 0 auto;
    }

    .section-pad {
        padding: clamp(72px, 9vw, 120px) 0;
    }

    .section-heading {
        max-width: 760px;
        margin-bottom: 34px;
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        margin-bottom: 18px;
        padding: 7px 14px;
        border-radius: var(--radius-pill);
        background: color-mix(in srgb, var(--blue) 10%, var(--canvas));
        color: var(--blue);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .eyebrow.light {
        background: color-mix(in srgb, var(--canvas) 12%, transparent);
        color: var(--on-dark);
    }

    .section-heading h2,
    .download-band h2 {
        font-size: clamp(2.15rem, 4.4vw, 4.8rem);
        font-weight: 500;
        letter-spacing: -0.055em;
        line-height: 0.98;
    }

    .section-heading p,
    .download-band p {
        max-width: 720px;
        margin-top: 18px;
        color: var(--body);
        font-size: clamp(1rem, 1.25vw, 1.16rem);
    }

    .feature-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: 18px;
    }

    .feature-card {
        min-height: 300px;
        padding: 28px;
        border: 1px solid var(--hairline);
        border-radius: 30px;
        background: var(--surface-card);
        transition:
            transform 180ms ease,
            border-color 180ms ease,
            box-shadow 180ms ease;
    }

    .feature-card:hover {
        transform: translateY(-4px);
        border-color: color-mix(in srgb, var(--blue) 26%, var(--hairline));
        box-shadow: 0 20px 42px color-mix(in srgb, var(--blue) 10%, transparent);
    }

    .feature-card.featured {
        background:
            radial-gradient(circle at 78% 18%, color-mix(in srgb, var(--accent-yellow) 34%, transparent), transparent 30%),
            var(--ink);
        color: var(--on-dark);
    }

    .feature-card.featured h3,
    .feature-card.featured p {
        color: var(--on-dark);
    }

    .card-icon {
        display: inline-grid;
        place-items: center;
        width: 50px;
        height: 50px;
        margin-bottom: 64px;
        border-radius: var(--radius-full);
        background: var(--blue-soft);
        color: var(--blue);
        font-weight: 900;
    }

    .featured .card-icon {
        background: var(--blue);
        color: var(--on-primary);
    }

    .feature-card h3 {
        margin-bottom: 12px;
        font-size: 1.35rem;
        font-weight: 800;
    }

    .feature-card p {
        color: var(--body);
    }

    .download-band {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 36px;
        align-items: center;
        margin-bottom: 64px;
        padding-inline: clamp(28px, 5vw, 64px);
        border-radius: 40px;
        background:
            radial-gradient(circle at 86% 28%, color-mix(in srgb, var(--blue) 44%, transparent), transparent 28%),
            var(--ink);
        color: var(--on-dark);
        overflow: hidden;
    }

    .download-band h2,
    .download-band p {
        color: var(--on-dark);
    }

    .download-band p {
        color: var(--on-dark-soft);
    }

    .download-actions {
        display: grid;
        gap: 14px;
        min-width: 240px;
    }

    .store-button {
        display: grid;
        gap: 2px;
        padding: 16px 22px;
        border-radius: 22px;
        background: var(--on-dark);
        color: var(--ink);
    }

    .store-button.secondary {
        border: 1px solid color-mix(in srgb, var(--on-dark) 18%, transparent);
        background: var(--surface-dark-elevated);
        color: var(--on-dark);
    }


    .dashboard-cta {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 48px;
        align-items: center;
        margin-bottom: 64px;
        padding: clamp(32px, 5vw, 56px) clamp(32px, 5vw, 64px);
        border-radius: 40px;
        background:
            radial-gradient(circle at 14% 38%, color-mix(in srgb, var(--accent-yellow) 28%, transparent), transparent 30%),
            radial-gradient(circle at 82% 64%, color-mix(in srgb, var(--blue) 22%, transparent), transparent 32%),
            var(--canvas);
        border: 1px solid var(--hairline);
        overflow: hidden;
    }

    .cta-content h2 {
        font-size: clamp(2.15rem, 4.4vw, 4.8rem);
        font-weight: 500;
        letter-spacing: -0.055em;
        line-height: 0.98;
    }

    .cta-content p {
        max-width: 580px;
        margin-top: 18px;
        color: var(--body);
        font-size: clamp(1rem, 1.25vw, 1.16rem);
    }

    .cta-action {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        margin-top: 26px;
        padding: 16px 30px;
        border-radius: var(--radius-pill);
        background: var(--ink);
        color: var(--on-dark);
        font-weight: 800;
        font-size: 1.05rem;
        transition:
            transform 140ms ease,
            box-shadow 180ms ease;
    }

    .cta-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 32px color-mix(in srgb, var(--ink) 22%, transparent);
    }

    .cta-action span {
        font-size: 1.2rem;
    }

    .cta-visual {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .cta-metric {
        display: grid;
        gap: 4px;
        padding: 20px 16px;
        border-radius: 24px;
        background: var(--surface-card);
        border: 1px solid var(--hairline);
        text-align: center;
    }

    .cta-metric strong {
        font-family: var(--font-heading);
        font-size: clamp(1.6rem, 2.2vw, 2.4rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--ink);
    }

    .cta-metric span {
        font-size: 0.82rem;
        color: var(--muted);
        font-weight: 600;
    }

    @media (max-width: 900px) {
        .dashboard-cta {
            grid-template-columns: 1fr;
            gap: 32px;
        }
    }

    @media (max-width: 640px) {
        .dashboard-cta {
            margin-bottom: 32px;
            border-radius: 30px;
            padding: 28px 24px;
        }

        .cta-visual {
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
        }

        .cta-metric {
            padding: 16px 8px;
            border-radius: 18px;
        }
    }
    .store-button small {
        color: inherit;
        opacity: 0.64;
        font-size: 0.78rem;
    }

    .store-button strong {
        font-family: var(--font-sans);
        font-size: 1.16rem;
        font-weight: 900;
    }

    @media (max-width: 900px) {
        .feature-grid,
        .download-band {
            grid-template-columns: 1fr;
        }

        .feature-card {
            min-height: 0;
        }

        .card-icon {
            margin-bottom: 36px;
        }

        .download-actions {
            min-width: 0;
        }
    }

    @media (max-width: 640px) {
        .promo-inner {
            width: min(100% - 32px, 520px);
        }

        .download-band {
            margin-bottom: 32px;
            border-radius: 30px;
        }
    }
</style>
