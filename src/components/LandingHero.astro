---
// Landing hero — Smart Caregiver app promotion
---

<section class="hero" aria-labelledby="hero-title">
    <div class="hero-bg" aria-hidden="true" />
    <div class="hero-inner">
        <header class="hero-header" aria-label="Smart Caregiver">
            <a class="brand" href="/" aria-label="Smart Caregiver">
                <span class="brand-mark">
                    <strong>Smart Caregiver</strong>
                </span>
            </a>
            <a class="pill-btn primary" href="/public-dashboard">Dashboard Publik</a>
        </header>

        <div class="hero-copy">
            <h1 id="hero-title">
                Pantau kesehatan&nbsp;lansia<br />
                lebih <span>tenang dan&nbsp;teratur.</span>
            </h1>
            <p>
                Aplikasi pendamping caregiver — catat kesehatan, atur jadwal obat,
                dapatkan rekomendasi aktivitas berbasis AI, dan pantau grafik tren
                semua dari satu genggaman.
            </p>

            <div class="hero-actions">
                <a class="pill-btn primary" href="#unduh">
                    Unduh Aplikasi
                    <span class="arrow" aria-hidden="true">→</span>
                </a>
                <a class="pill-btn secondary" href="#cara-kerja">
                    Lihat Cara Kerja
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        width: 100vw;
        margin: 0 calc(50% - 50vw);
        min-height: 100vh;
        min-height: 100svh;
        overflow: hidden;
        color: var(--ink);
    }

    /* background.webp — pure image, no overlay */
    .hero-bg {
        position: absolute;
        inset: 0;
        background: url("/images/background.webp") center 30% / cover no-repeat;
        pointer-events: none;
        z-index: 0;
    }

    @media (max-width: 1024px) {
        .hero-bg {
            background: url("/images/background.webp") center 30% / cover no-repeat;
        }
    }

    @media (max-width: 768px) {
        .hero-bg {
            background: url("/images/background.webp") center 20% / cover no-repeat;
        }
    }

    @media (max-width: 480px) {
        .hero-bg {
            background: url("/images/background.webp") center top / auto 100% no-repeat;
        }
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-rows: auto 1fr;
        width: min(100% - 64px, 1280px);
        height: 100%;
        min-height: 100vh;
        min-height: 100svh;
        margin: 0 auto;
        padding: clamp(14px, 2vw, 28px) 0;
    }

    .hero-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-lg);
    }

    .brand {
        display: inline-flex;
        align-items: center;
        gap: 13px;
        color: var(--ink);
    }

    .brand strong {
        font-family: var(--font-heading);
        font-size: clamp(1rem, 1.35vw, 1.25rem);
        font-weight: 700;
        letter-spacing: -0.02em;
    }

    .hero-header .pill-btn.primary {
        font-size: 0.88rem;
        padding: 9px 18px;
    }

    .hero-copy {
        align-self: center;
        justify-self: center;
        width: min(900px, 100%);
        margin-top: clamp(-60px, -6vh, -20px);
        text-align: center;
    }

    h1 {
        color: var(--ink);
        font-size: clamp(2.8rem, 6.5vw, 5rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.1;
        font-family: var(--font-heading);
        text-shadow: 0 2px 8px rgba(255,255,255,0.5);
    }

    h1 span {
        display: inline-block;
        text-shadow: 0 2px 8px rgba(255,255,255,0.5);
    }

    .hero-copy p {
        max-width: 700px;
        margin: 20px auto 0;
        color: var(--charcoal);
        font-size: clamp(1.05rem, 1.3vw, 1.25rem);
        line-height: 1.65;
        text-shadow: 0 1px 6px rgba(255,255,255,0.5);
    }

    .hero-actions {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin-top: 32px;
    }

    .hero-actions .pill-btn {
        min-width: 200px;
        padding: 14px 28px;
        font-size: 15px;
    }

    @media (max-width: 1024px) {
        .hero-inner {
            width: min(100% - 40px, 980px);
        }
    }

    @media (max-width: 768px) {
        .hero-actions {
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }

        .hero-actions .pill-btn {
            width: min(100%, 320px);
            min-width: 0;
        }

        .hero-header .pill-btn.primary {
            display: none;
        }
    }

    @media (max-width: 480px) {
        .hero-inner {
            width: min(100% - 24px, 520px);
            padding-top: 12px;
        }

        .hero-copy {
            margin-top: 0;
        }

        h1 {
            font-size: clamp(2.2rem, 10vw, 3rem);
        }

        .hero-copy p {
            font-size: 1rem;
            margin-top: 14px;
        }
    }
</style>
