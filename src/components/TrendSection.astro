---
import type { TrendSeries, RegionInterest } from '../lib/types';

export interface Props {
  series: TrendSeries[];
  regions: RegionInterest[];
}

const { series, regions } = Astro.props;
const maxRegionScore = Math.max(...regions.map((r) => r.score));
const trendRange = series.length > 1 ? `${series[0].month} hingga ${series.at(-1)?.month}` : series[0]?.month;

const trendConfig = [
  { key: 'lansia', label: 'lansia', color: 'var(--blue)' },
  { key: 'kesehatan', label: 'kesehatan lansia', color: 'var(--teal)' },
  { key: 'senam', label: 'senam lansia', color: 'var(--green)' },
  { key: 'posyandu', label: 'posyandu lansia', color: 'var(--orange)' },
] as const;

function seriesPoints(key: string) {
  return series.map((point, i) => {
    const x = 44 + (i / (series.length - 1)) * 500;
    const val = Number(point[key]) || 0;
    const y = 220 - ((val - 10) / 85) * 170;
    return { x, y, value: val, month: point.month };
  });
}
---

<section id="publik" class="section-block">
  <div class="section-title">
    <h2>Minat Publik</h2>
  </div>
  <p class="section-copy">
    Google Trends menunjukkan minat pencarian publik terhadap topik lansia untuk
    periode {trendRange}. Nilai merupakan indeks minat relatif dari data terbaru.
  </p>

  <div class="two-panels">
    <div class="panel scroll-panel">
      <h3>Tren Pencarian Bulanan</h3>
      <svg
        class="line-chart"
        viewBox="0 0 600 280"
        role="img"
        aria-labelledby="trend-chart-title trend-chart-desc"
      >
        <title id="trend-chart-title">Line chart Google Trends</title>
        <desc id="trend-chart-desc">
          Keyword terkait lansia pada periode {trendRange}
        </desc>
        <line x1="44" y1="220" x2="560" y2="220" class="axis" />
        <line x1="44" y1="40" x2="44" y2="220" class="axis" />

        {trendConfig.map((item) => {
          const pts = seriesPoints(item.key);
          return (
            <g class="chart-series" data-key={item.key}>
              <polyline
                points={pts.map((p) => `${p.x},${p.y}`).join(' ')}
                fill="none"
                stroke={item.color}
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              {pts.map((p) => (
                <circle
                  cx={p.x}
                  cy={p.y}
                  r="4"
                  fill={item.color}
                  class="chart-point"
                  data-label={`${item.label} · ${p.month}`}
                  data-value={String(p.value)}
                />
              ))}
            </g>
          );
        })}

        {series.map((point, i) => (
          <text
            x={44 + (i / (series.length - 1)) * 500}
            y="250"
            text-anchor="middle"
            class="axis-label"
          >
            {point.month}
          </text>
        ))}
      </svg>

      <div class="chart-tooltip" hidden></div>

      <div class="legend-inline">
        {trendConfig.map((item) => (
          <button type="button" data-key={item.key}>
            <i style={`background: ${item.color}`} />
            {item.label}
          </button>
        ))}
      </div>
    </div>

    <div class="panel">
      <h3>Ranking Wilayah</h3>
      <div class="region-list" role="list" aria-label="Ranking minat provinsi">
        {regions.map((item, index) => (
          <div class="region-row" role="listitem">
            <span class="rank">{index + 1}</span>
            <strong>{item.region}</strong>
            <small>{item.keyword}</small>
            <b>{item.score}</b>
            <div class="mini-track" aria-hidden="true">
              <span style={`width: ${(item.score / maxRegionScore) * 100}%`} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const panel = document.querySelector('#publik .scroll-panel');
  const tooltip = panel?.querySelector<HTMLElement>('.chart-tooltip');

  panel?.querySelectorAll<SVGCircleElement>('.chart-point').forEach((point) => {
    point.addEventListener('mouseenter', () => showTooltip(point));
    point.addEventListener('mouseleave', hideTooltip);
  });

  function showTooltip(point: SVGCircleElement) {
    if (!tooltip || !panel) return;
    const label = point.getAttribute('data-label');
    const value = point.getAttribute('data-value');
    tooltip.innerHTML = `<strong>${value}</strong><span>${label}</span>`;
    const pointRect = point.getBoundingClientRect();
    const panelRect = panel.getBoundingClientRect();
    tooltip.style.left = `${pointRect.left - panelRect.left + panel.scrollLeft + pointRect.width / 2}px`;
    tooltip.style.top = `${pointRect.top - panelRect.top}px`;
    tooltip.hidden = false;
  }

  function hideTooltip() {
    if (tooltip) tooltip.hidden = true;
  }

  document.querySelectorAll<HTMLButtonElement>('#publik .legend-inline button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-key');
      const series = document.querySelector<SVGGElement>(`#publik .chart-series[data-key="${key}"]`);
      const hidden = btn.classList.toggle('is-hidden');
      if (series) series.style.opacity = hidden ? '0.08' : '1';
    });
  });
</script>
