---
import type { WhoIndicator } from '../lib/types';

export interface Props {
  indicators: WhoIndicator[];
}

const { indicators } = Astro.props;
const allValues = indicators.flatMap((i) => i.values.map((v) => v.value));
const min = Math.min(...allValues);
const max = Math.max(...allValues);
const colors = ['var(--blue)', 'var(--teal)', 'var(--green)', 'var(--orange)'];

function seriesPoints(values: { year: number; value: number }[], min: number, max: number) {
  return values.map((point, i) => ({
    x: 44 + (i / (values.length - 1)) * 500,
    y: 220 - ((point.value - min) / (max - min)) * 170,
    year: point.year,
    value: point.value,
  }));
}
---

<section id="tren" class="section-block">
  <div class="section-title">
    <h2>Tren Kesehatan (WHO)</h2>
  </div>
  <p class="section-copy">
    WHO menyediakan data historis 1980–2022 untuk empat indikator kesehatan yang
    relevan dengan lansia di Indonesia: hipertensi, diabetes, obesitas, dan harapan hidup.
  </p>

  <div class="panel scroll-panel">
    <h3>Indikator WHO 1980–2022</h3>
    <svg
      class="line-chart"
      viewBox="0 0 600 280"
      role="img"
      aria-labelledby="who-chart-title who-chart-desc"
    >
      <title id="who-chart-title">Line chart indikator WHO</title>
      <desc id="who-chart-desc">
        Empat indikator: hipertensi, diabetes, obesitas, dan harapan hidup kelompok 60+
      </desc>
      <line x1="44" y1="220" x2="560" y2="220" class="axis" />
      <line x1="44" y1="40" x2="44" y2="220" class="axis" />

      {indicators.map((indicator, index) => {
        const pts = seriesPoints(indicator.values, min, max);
        return (
          <g class="chart-series" data-key={indicator.code}>
            <polyline
              points={pts.map((p) => `${p.x},${p.y}`).join(' ')}
              fill="none"
              stroke={colors[index]}
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            {pts.map((p) => (
              <circle
                cx={p.x}
                cy={p.y}
                r="4"
                fill={colors[index]}
                class="chart-point"
                data-label={`${indicator.keyword} · ${p.year}`}
                data-value={`${p.value}${indicator.unit}`}
              />
            ))}
          </g>
        );
      })}

      {indicators[0].values.map((point, i) => (
        <text
          x={44 + (i / (indicators[0].values.length - 1)) * 500}
          y="250"
          text-anchor="middle"
          class="axis-label"
        >
          {point.year}
        </text>
      ))}
    </svg>

    <div class="chart-tooltip" hidden></div>

    <div class="legend-grid">
      {indicators.map((indicator, index) => (
        <button type="button" class="legend-item" data-key={indicator.code}>
          <span class="swatch" style={`background: ${colors[index]}`} />
          <strong>{indicator.keyword}</strong>
          <small>{indicator.meaning}</small>
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  const panel = document.querySelector('#tren .scroll-panel');
  const tooltip = panel?.querySelector<HTMLElement>('.chart-tooltip');

  panel?.querySelectorAll<SVGCircleElement>('.chart-point').forEach((point) => {
    point.addEventListener('mouseenter', () => showTooltip(point));
    point.addEventListener('mouseleave', hideTooltip);
  });

  function showTooltip(point: SVGCircleElement) {
    if (!tooltip || !panel) return;
    const label = point.getAttribute('data-label');
    const value = point.getAttribute('data-value');
    tooltip.innerHTML = `<strong>${value}</strong><span>${label}</span>`;
    const pointRect = point.getBoundingClientRect();
    const panelRect = panel.getBoundingClientRect();
    tooltip.style.left = `${pointRect.left - panelRect.left + panel.scrollLeft + pointRect.width / 2}px`;
    tooltip.style.top = `${pointRect.top - panelRect.top}px`;
    tooltip.hidden = false;
  }

  function hideTooltip() {
    if (tooltip) tooltip.hidden = true;
  }

  document.querySelectorAll<HTMLButtonElement>('#tren .legend-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-key');
      const series = document.querySelector<SVGGElement>(`#tren .chart-series[data-key="${key}"]`);
      const hidden = btn.classList.toggle('is-hidden');
      if (series) series.style.opacity = hidden ? '0.08' : '1';
    });
  });
</script>
